{
  "name": "@xcg/proxy",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "bin": {
    "xcg-proxy": "./bin/xcg-proxy"
  },
  "scripts": {
    "build": "esbuild src/main.ts --bundle --platform=node --target=node22 --format=cjs --outfile=dist/xcg-proxy.cjs",
    "stub": "esbuild scripts/stub-orchestrator.ts --bundle --platform=node --target=node22 --format=cjs --outfile=dist/xcg-stub.cjs && node dist/xcg-stub.cjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "ulid": "^2.3.0"
  },
  "devDependencies": {
    "@types/node": "^22.12.0",
    "esbuild": "^0.24.0",
    "vitest": "^2.1.0"
  }
}
