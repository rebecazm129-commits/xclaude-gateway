{
  "name": "@xcg/proxy",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    "./detection/selftest": "./src/detection/selftest.ts",
    "./credentials": "./src/credentials.ts",
    "./cchook-ingest": "./src/cchook-ingest.ts"
  },
  "bin": {
    "xcg-proxy": "./bin/xcg-proxy",
    "xcg-config": "./bin/xcg-config",
    "xcg-cchook": "./bin/xcg-cchook"
  },
  "scripts": {
    "build": "pnpm run build:main && pnpm run build:worker && pnpm run build:config && pnpm run build:cchook",
    "build:main": "esbuild src/cli-entry.ts --bundle --platform=node --target=node22 --format=cjs --outfile=dist/xcg-proxy.cjs",
    "build:worker": "esbuild src/detection/ner/worker.ts --bundle --platform=node --target=node22 --format=cjs --loader:.node=copy --alias:sharp=./scripts/empty-stub.cjs --alias:onnxruntime-web=./scripts/empty-stub.cjs --outfile=dist/xcg-ner-worker.cjs && pnpm run copy:dylib",
    "build:config": "esbuild src/config/cli-entry.ts --bundle --platform=node --target=node22 --format=cjs --outfile=dist/xcg-config.cjs",
    "build:cchook": "esbuild src/cchook-entry.ts --bundle --platform=node --target=node22 --format=cjs --outfile=dist/xcg-cchook.cjs",
    "copy:dylib": "node scripts/copy-dylib.mjs",
    "fetch:model": "node scripts/fetch-model.mjs",
    "stub": "esbuild scripts/stub-orchestrator.ts --bundle --platform=node --target=node22 --format=cjs --outfile=dist/xcg-stub.cjs && node dist/xcg-stub.cjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@huggingface/transformers": "^4.2.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@xcg/shared": "workspace:*",
    "onnxruntime-node": "1.24.3",
    "ulid": "^2.3.0"
  },
  "devDependencies": {
    "@types/node": "^22.12.0",
    "esbuild": "^0.24.0",
    "vitest": "^2.1.0"
  }
}
